# VespAI Configuration
# Copy to .env and customize for your setup

# SMS Alert Configuration (Optional)
# LOX24_API_KEY=your_api_key_here
# PHONE_NUMBER=+1234567890
# DOMAIN_NAME=your-domain.com

# Model Configuration
MODEL_PATH=models/L4-YOLOV26-asianhornet_2026-03-13_08-57-52_ncnn_model
CONFIDENCE_THRESHOLD=0.6
VESPAI_CLASS_MAP=1:crabro,2:velutina
VESPAI_DATASET_PATH=datasets/Detection Asian-hornet.v1i.tfrecord/test/asianhornet.tfrecord

# Camera Configuration
# Easy camera backend selection:
# - usb: use /dev/video* devices (webcams, USB capture)
# - picamera2: use Raspberry Pi CSI camera (Camera Module 3)
# - auto: try USB first, then Picamera2 fallback
VESPAI_CAMERA_SOURCE=usb
CAMERA_INDEX=0
VESPAI_CAMERA_DEVICE=/dev/video8

# Quick switch examples:
# VESPAI_CAMERA_SOURCE=picamera2
# VESPAI_CAMERA_DEVICE=

# VESPAI_CAMERA_SOURCE=auto
# VESPAI_CAMERA_DEVICE=/dev/video0

RESOLUTION=1280x720
CAMERA_RESOLUTION=1280x720
CAMERA_FPS=30

# Detection Configuration
SAVE_DETECTIONS=true
SAVE_DIRECTORY=monitor/detections
DETECTION_RETENTION_DAYS=21
FRAME_DELAY=0.35
DATASET_FRAME_DELAY=5.0

# Motion Detection (Optional)
ENABLE_MOTION_DETECTION=false
MIN_MOTION_AREA=5000

# Web Interface
WEB_HOST=0.0.0.0
WEB_PORT=8081
